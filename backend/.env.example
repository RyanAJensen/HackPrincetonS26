K2_API_KEY=ifm-...
# Dedalus API key for DedalusRunner (`RUNTIME_MODE=dedalus`) or Dedalus Machines (`RUNTIME_MODE=swarm`)
DEDALUS_API_KEY=dsk-...
# Optional BYOK: lets Dedalus route requests using your own upstream provider credits.
DEDALUS_PROVIDER=anthropic
DEDALUS_PROVIDER_KEY=
DEDALUS_PROVIDER_MODEL=claude-sonnet-4-5-20250929
DEDALUS_MODEL=anthropic/claude-sonnet-4-20250514
DEDALUS_MAX_STEPS=5
DEDALUS_RUNNER_DEBUG=true
DEDALUS_RUNNER_VERBOSE=true
# Dedalus Machines swarm defaults
DEDALUS_DCS_BASE_URL=https://dcs.dedaluslabs.ai/v1
DEDALUS_MACHINE_VCPU=0.25
DEDALUS_MACHINE_MEMORY_MIB=512
DEDALUS_MACHINE_STORAGE_GIB=1
DEDALUS_MACHINE_READY_TIMEOUT_SECONDS=180
DEDALUS_MACHINE_BOOTSTRAP_TIMEOUT_SECONDS=600
DEDALUS_MACHINE_EXEC_TIMEOUT_SECONDS=900
DEDALUS_MACHINE_RUNNER_DEBUG=false
DEDALUS_MACHINE_RUNNER_VERBOSE=false
# Fail startup if dedalus expected but SDK/key missing; forbid K2 fallback from DedalusAgentRuntime
DEDALUS_STRICT=false
RUNTIME_MODE=dedalus        # "dedalus" | "swarm" | "local"
