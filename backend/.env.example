ANTHROPIC_API_KEY=sk-ant-...
# DedalusRunner (dedalus_labs) — optional; without key, agents use local K2
DEDALUS_API_KEY=
DEDALUS_MODEL=anthropic/claude-sonnet-4-20250514
DEDALUS_MAX_STEPS=5
DEDALUS_RUNNER_DEBUG=true
DEDALUS_RUNNER_VERBOSE=true
# Fail startup if dedalus expected but SDK/key missing; forbid K2 fallback from DedalusAgentRuntime
DEDALUS_STRICT=false
RUNTIME_MODE=dedalus        # "dedalus" | "local"
